# Plantilla de configuración. Copiar a .env y completar con los valores de cada máquina.
# El .env real NO se sube a git (está en .gitignore).

# --- Credenciales de la app de Mercado Libre ---
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=
ML_SITE_ID=MLA

# --- Rutas a los DBF del ERP (solo lectura) ---
# En el SERVER: rutas locales reales del ERP, p. ej. C:\Nexus\Datos
# En la NOTEBOOK (desarrollo): carpeta con una copia de los DBF,
#   o un drive de red mapeado al server, p. ej. Z:\Datos
DBF_DIR=
TAPAS_DIR=
